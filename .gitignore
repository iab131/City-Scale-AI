
## .gitignore

```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Logs
*.log

# Jupyter
.ipynb_checkpoints/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Python env files
.env
.env.*

# Test / cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Data files
data/
!data/.gitkeep

# Model outputs
outputs/
runs/
checkpoints/
*.pt
*.pth
*.ckpt
*.onnx
*.npz
*.npy

# Figures / generated artifacts
*.png
*.jpg
*.jpeg
*.pdf

# Local notebooks outputs
notebooks/.ipynb_checkpoints/

# Temporary files
tmp/
temp/
*.tmp

# macOS / Windows misc
Desktop.ini